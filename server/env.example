# ─── Google Cloud / Gmail ─────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# From Google Cloud Console → your project ID (shown in the header dropdown)
GOOGLE_CLOUD_PROJECT=your-project-id

# The Pub/Sub topic name you create in step 4 below
PUBSUB_TOPIC=gmail-push-notifications

# ─── Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────
# Local:      postgresql://postgres:password@localhost:5432/hotel_ops
# Railway:    paste from Railway dashboard
DATABASE_URL=

# ─── App ──────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-random-string-openssl-rand-hex-32
CLIENT_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
